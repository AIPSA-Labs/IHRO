---
import { translations } from "../../locals/about/getInvolved";
import { HeartHandshake } from "@lucide/astro";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="relative py-24 px-4 sm:px-6 md:px-10 overflow-hidden bg-white">
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <h2 class="animate-on-scroll text-3xl md:text-5xl font-extrabold mb-6 text-justice-navy">{t.title}</h2>
    <p class="animate-on-scroll delay-1 text-lg md:text-xl text-on-surface-variant mb-10 max-w-2xl mx-auto">{t.subtitle}</p>
    
    <div class="animate-on-scroll delay-2 flex justify-center">
      <a href="/volunteer" class="group relative overflow-hidden bg-honor-gold text-white font-semibold px-8 py-4 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 active:scale-95">
        <span class="relative z-10 flex items-center justify-center gap-2">
          <HeartHandshake class="w-5 h-5" />
          {t.cta.volunteer}
        </span>
      </a>
    </div>
  </div>
</section>
