
---
import { translations } from "../../locals/home/hero";
import heroImg from "../../assets/hero.png";

type Locale = "en" | "hi" | "fr";
const { local = "en" } = Astro.params ?? {};
const t = translations[local as Locale] || translations["en"];
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden pt-20">

  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img src={heroImg.src} alt="IHRO Hero" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-justice-navy/90 via-justice-navy/40 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-6 py-20">
    <div class="max-w-xl">
      <h1 class="font-['Hanken_Grotesk'] text-[36px] md:text-[52px] leading-[60px] tracking-[-0.02em] font-bold text-white mb-6">
        {t.title}
      </h1>
      <p class="font-['Inter'] text-[18px] leading-[28px] text-white/80 mb-10">
        {t.subtitle}
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="/campaigns"
          class="bg-action-blue text-on-primary font-['Inter'] text-sm font-semibold px-8 py-4 rounded-lg hover:bg-secondary transition-all shadow-lg active:scale-95"
        >
          {t.cta}
        </a>
        <a
          href="#mission"
          class="bg-white/10 backdrop-blur-md border border-white/20 text-white font-['Inter'] text-sm font-semibold px-8 py-4 rounded-lg hover:bg-white/20 transition-all active:scale-95"
        >
          Our Mission
        </a>
      </div>
    </div>
  </div>

</section>
