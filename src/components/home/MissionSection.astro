---
import { translations } from "../../locals/home/mission";

type Locale = "en" | "hi" | "fr";
const { local = "en" } = Astro.params ?? {};
const t = translations[local as Locale] || translations["en"];
---

<section id="mission" class="py-20 md:py-32 px-4 md:px-6 max-w-7xl mx-auto">
  <div class="text-center mb-16">
    <span class="animate-on-scroll text-action-blue font-['Inter'] text-sm font-semibold uppercase tracking-widest mb-4 block">{t.coreValuesLabel}</span>
    <h2 class="animate-on-scroll delay-1 font-['Hanken_Grotesk'] text-[32px] md:text-[40px] leading-[48px] tracking-[-0.01em] font-semibold text-justice-navy">
      {t.title}
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {t.missionPoints.map((point, index) => (
      <div class={`animate-on-scroll delay-${index + 1} p-8 rounded-xl border border-slate-200 bg-white hover:shadow-xl transition-shadow group`}>
        <div class="w-16 h-16 bg-surface-container rounded-lg flex items-center justify-center mb-6 text-justice-navy group-hover:bg-justice-navy group-hover:text-white transition-colors">
          <span class="material-symbols-outlined text-[40px]">{point.icon}</span>
        </div>
        <h3 class="font-['Hanken_Grotesk'] text-[28px] leading-[36px] font-semibold mb-4">{point.title}</h3>
        <p class="text-on-surface-variant leading-relaxed">{point.text}</p>
      </div>
    ))}
  </div>
</section>
