---
import { translations } from "../../locals/about/hero";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="relative bg-background text-foreground py-28 sm:py-36 px-4 sm:px-6 md:px-10 overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-0 w-96 h-96 bg-primary rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-accent rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <div class="animate-on-scroll scroll-scale inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 mb-6">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      <span class="text-sm font-medium text-primary">About Us</span>
    </div>

    <h1 class="animate-on-scroll delay-1 text-4xl sm:text-5xl md:text-6xl font-extrabold mb-6 leading-tight">{t.title}</h1>
    <p class="animate-on-scroll delay-2 text-lg sm:text-xl md:text-2xl text-muted-foreground mb-6 leading-relaxed">{t.subtitle}</p>
    <p class="animate-on-scroll delay-3 text-base md:text-lg text-muted-foreground/80 max-w-3xl mx-auto">{t.description}</p>
  </div>
</section>
