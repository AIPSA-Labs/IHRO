---
import { translations } from "../../locals/home/presence";
import digitalMap from "../../assets/digital-map.png";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="py-20 px-4 md:px-6 max-w-7xl mx-auto overflow-hidden" id="presence">
  <div class="flex flex-col md:flex-row gap-16 items-center">

    <!-- Left Content -->
    <div class="w-full md:w-1/2">
      <h2 class="animate-on-scroll scroll-left font-['Hanken_Grotesk'] text-[32px] md:text-[40px] leading-[48px] tracking-[-0.01em] font-semibold text-justice-navy mb-8">
        {t.title}
      </h2>

      <div class="space-y-8">
        <!-- International Offices -->
        <div class="animate-on-scroll scroll-left delay-1">
          <h4 class="font-['Inter'] text-sm font-semibold text-action-blue uppercase tracking-widest mb-4">
            {t.internationalTitle}
          </h4>
          <div class="flex flex-wrap gap-3">
            {t.internationalOffices.map((office) => (
              <span class="bg-surface-container px-4 py-2 rounded-full font-['Inter'] text-sm text-on-surface">{office.country}</span>
            ))}
          </div>
        </div>

        <!-- National Chapters -->
        <div class="animate-on-scroll scroll-left delay-2">
          <h4 class="font-['Inter'] text-sm font-semibold text-action-blue uppercase tracking-widest mb-4">
            {t.nationalTitle}
          </h4>
          <div class="flex flex-wrap gap-3">
            {t.nationalChapters.map((chapter) => (
              <span class="bg-surface-container px-4 py-2 rounded-full font-['Inter'] text-sm text-on-surface">{chapter}</span>
            ))}
          </div>
        </div>

        <!-- State Chapters -->
        <div class="animate-on-scroll scroll-left delay-3">
          <h4 class="font-['Inter'] text-sm font-semibold text-action-blue uppercase tracking-widest mb-4">
            {t.stateTitle}
          </h4>
          <div class="flex flex-wrap gap-3">
            {t.stateChapters.map((chapter) => (
              <span class="bg-surface-container-low border border-slate-200 px-4 py-2 rounded-full font-['Inter'] text-xs text-on-surface">{chapter}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Right Map -->
    <div class="animate-on-scroll scroll-right w-full md:w-1/2 relative">
      <div class="aspect-square bg-slate-100 rounded-2xl flex items-center justify-center p-8 relative">
        <div class="absolute inset-0 bg-blue-100/30 rounded-2xl animate-pulse"></div>
        <img src={digitalMap.src} alt="Global Network Map" class="w-full h-full object-contain relative z-10" />
      </div>
    </div>

  </div>
</section>
