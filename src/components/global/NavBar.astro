---
import { supportedLocales } from "../../locals/languages";
---

<header class="fixed top-0 w-full z-50 liquid-glass shadow-sm">
<nav class="flex justify-between items-center px-4 md:px-6 py-4 w-full">

  <a href="/" class="flex items-center gap-3 cursor-pointer">
    <img src="/favicon.svg" alt="IHRO Logo" class="h-10 w-10 object-contain" />
    <span class="font-['Hanken_Grotesk'] text-[20px] md:text-[24px] text-on-surface font-bold tracking-tight">IHRO</span>
    <span class="hidden md:inline text-on-surface font-['Inter'] text-sm font-medium">— International Human Rights Organization</span>
  </a>

  <!-- Menu Button (all screen sizes) -->
  <button class="p-2 text-on-surface cursor-pointer" onclick="toggleDrawer()">
    <span class="material-symbols-outlined">menu</span>
  </button>

</nav>
</header>

<script>
  // @ts-ignore
  window.toggleDrawer = function() {
    const drawer = document.getElementById('drawer');
    drawer?.classList.toggle('-translate-y-full');
    drawer?.classList.toggle('translate-y-0');
  };
</script>
