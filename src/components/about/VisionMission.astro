---
import { translations } from "../../locals/about/missionVision";
import { Target, Eye } from "@lucide/astro";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="bg-background text-foreground py-24 px-4 sm:px-6 md:px-10 relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center relative z-10">
    
    <!-- Mission -->
    <div class="animate-on-scroll scroll-left group glass-card rounded-3xl p-8 sm:p-10 hover-lift">
      <div class="flex items-center gap-4 mb-6">
        <div class="p-4 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 text-primary group-hover:scale-110 transition-transform duration-300">
          <Target class="w-8 h-8" />
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold">{t.mission.title}</h2>
      </div>
      <p class="text-lg text-muted-foreground leading-relaxed">{t.mission.description}</p>
    </div>

    <!-- Vision -->
    <div class="animate-on-scroll scroll-right group glass-card rounded-3xl p-8 sm:p-10 hover-lift">
      <div class="flex items-center gap-4 mb-6">
        <div class="p-4 rounded-2xl bg-gradient-to-br from-accent/20 to-accent/5 text-accent group-hover:scale-110 transition-transform duration-300">
          <Eye class="w-8 h-8" />
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold">{t.vision.title}</h2>
      </div>
      <p class="text-lg text-muted-foreground leading-relaxed">{t.vision.description}</p>
    </div>

  </div>
</section>
