---
import { footerTranslations } from "../../locals/global/footer";

const year = new Date().getFullYear();

type Locale = "en" | "hi" | "fr";
const { local = "en" } = Astro.params ?? {};
const t = footerTranslations[local as Locale] || footerTranslations["en"];
---

<footer class="bg-black text-white pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">

      <!-- Brand -->
      <div class="md:col-span-4">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center p-1">
            <img src="/favicon.svg" alt="IHRO Logo" class="w-full h-full object-contain" />
          </div>
          <span class="font-['Hanken_Grotesk'] text-[28px] font-bold tracking-tight">IHRO</span>
        </div>
        <p class="text-white/80 font-['Inter'] leading-relaxed mb-8">
          {t.brandDesc}
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-honor-gold transition-colors">
            <span class="material-symbols-outlined text-[20px]">public</span>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-honor-gold transition-colors">
            <span class="material-symbols-outlined text-[20px]">share</span>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-honor-gold transition-colors">
            <span class="material-symbols-outlined text-[20px]">rss_feed</span>
          </a>
        </div>
      </div>

      <!-- Organization -->
      <div class="md:col-span-2">
        <h4 class="font-['Inter'] text-sm font-semibold text-white/70 mb-6 uppercase tracking-widest">{t.linksTitle}</h4>
        <ul class="space-y-4">
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href={`/${local}/`}>{t.links.home}</a></li>
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href={`/${local}/about`}>{t.links.about}</a></li>
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href="#">{t.links.annualReport}</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div class="md:col-span-2">
        <h4 class="font-['Inter'] text-sm font-semibold text-white/70 mb-6 uppercase tracking-widest">{t.supportTitle}</h4>
        <ul class="space-y-4">
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href="#">{t.supportLinks.donate}</a></li>
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href="#">{t.supportLinks.volunteer}</a></li>
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href="#">{t.supportLinks.newsletter}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="md:col-span-2">
        <h4 class="font-['Inter'] text-sm font-semibold text-white/70 mb-6 uppercase tracking-widest">{t.legalTitle}</h4>
        <ul class="space-y-4">
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href={`/${local}/privacy`}>{t.links.privacy}</a></li>
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href={`/${local}/terms`}>{t.links.terms}</a></li>
          <li><a class="text-white/80 hover:text-white transition-colors font-['Inter']" href="#">{t.links.ethicsCharter}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-2">
        <h4 class="font-['Inter'] text-sm font-semibold text-white/70 mb-6 uppercase tracking-widest">{t.contactTitle}</h4>
        <div class="space-y-4 text-white/80 text-sm">
          <p class="flex items-start gap-3">
            <span class="material-symbols-outlined text-honor-gold">mail</span>
            info@ihro.world
          </p>
          <p class="flex items-start gap-3">
            <span class="material-symbols-outlined text-honor-gold">call</span>
            +4917645983857
          </p>
          <p class="flex items-start gap-3">
            <span class="material-symbols-outlined text-honor-gold">location_on</span>
            Mallinckrodstraße 167, Dortmund, Germany
          </p>
        </div>
      </div>

    </div>

    <!-- Newsletter -->
    <div class="border-t border-white/10 pt-12 pb-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8 w-full">
        <div class="text-left max-w-md">
          <h3 class="font-['Hanken_Grotesk'] text-[28px] leading-[36px] font-semibold text-white mb-2">{t.newsletter.title}</h3>
          <p class="text-white/60 font-['Inter']">{t.newsletter.subtitle}</p>
        </div>
        <div class="w-full md:w-auto flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            placeholder={t.newsletter.placeholder}
            required
            class="flex-grow md:w-[450px] p-4 rounded-lg border-none focus:ring-2 focus:ring-action-blue outline-none bg-white/10 text-white placeholder:text-white/60 font-['Inter']"
          />
          <button class="bg-action-blue text-on-primary px-8 py-4 rounded-lg font-['Inter'] text-sm font-semibold hover:bg-secondary transition-all active:scale-95 shadow-lg cursor-pointer">
            {t.newsletter.cta}
          </button>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/80 font-['Inter'] text-sm font-semibold">&copy; {year} International Human Rights Organization. {t.copyright}</p>
      <div class="flex gap-8">
        <a class="text-white/80 hover:text-white text-xs uppercase tracking-widest transition-colors" href="#">{t.termsOfService}</a>
        <a class="text-white/80 hover:text-white text-xs uppercase tracking-widest transition-colors" href="#">{t.cookiePolicy}</a>
      </div>
    </div>
  </div>
</footer>
