---
import { translations } from "../../locals/home/newsletter";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="py-20 bg-surface-container-low border-t border-outline-variant">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="animate-on-scroll scroll-scale bg-justice-navy rounded-xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 shadow-xl">
      <div class="text-left max-w-md">
        <h2 class="font-['Hanken_Grotesk'] text-[28px] leading-[36px] font-semibold text-white mb-2">{t.title}</h2>
        <p class="text-primary-fixed-dim font-['Inter']">{t.subtitle}</p>
      </div>
      <div class="w-full md:w-auto flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          placeholder={t.placeholder}
          required
          class="flex-grow md:w-80 p-4 rounded-lg border-none focus:ring-2 focus:ring-action-blue outline-none bg-white/10 text-white placeholder:text-white/60"
        />
        <button class="bg-action-blue text-on-primary px-8 py-4 rounded-lg font-['Inter'] text-sm font-semibold hover:bg-secondary transition-all active:scale-95 shadow-lg">
          {t.cta}
        </button>
      </div>
    </div>
  </div>
</section>
