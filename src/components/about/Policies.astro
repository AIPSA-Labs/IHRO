---
import { translations } from "../../locals/about/policies";
import { Shield, Scale, BookOpen, Users, Globe, Heart } from "@lucide/astro";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];

const policyIcons = [Shield, Scale, BookOpen, Users, Globe, Heart];
---

<section class="bg-background text-foreground py-24 px-4 sm:px-6 md:px-10 relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto text-center mb-16 relative z-10">
    <h2 class="animate-on-scroll text-3xl md:text-5xl font-extrabold mb-4">{t.title}</h2>
    <p class="animate-on-scroll delay-1 text-lg md:text-xl text-muted-foreground mt-4 max-w-3xl mx-auto">{t.subtitle}</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 max-w-7xl mx-auto relative z-10">
    {t.policies.map((policy, index) => {
      const Icon = policyIcons[index % policyIcons.length];
      return (
        <div class={`animate-on-scroll delay-${(index % 6) + 1} group glass-card rounded-3xl p-8 flex flex-col items-center text-center hover-lift`}>
          <div class="p-4 rounded-2xl bg-gradient-to-br from-primary/15 to-primary/5 text-primary mb-6 group-hover:scale-110 transition-transform duration-300">
            <Icon class="w-8 h-8" />
          </div>
          <h3 class="text-xl font-bold mb-3">{policy.title}</h3>
          <p class="text-muted-foreground leading-relaxed">{policy.description}</p>
        </div>
      );
    })}
  </div>
</section>
