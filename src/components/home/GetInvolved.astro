---
import { translations } from "../../locals/home/getInvolved";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="bg-justice-navy text-white py-20">
  <div class="max-w-7xl mx-auto px-4 md:px-6 text-center">
    <h2 class="animate-on-scroll font-['Hanken_Grotesk'] text-[32px] md:text-[40px] leading-[48px] tracking-[-0.01em] font-semibold mb-6">
      {t.title}
    </h2>
    <p class="animate-on-scroll delay-1 text-white/70 font-['Inter'] mb-12 max-w-xl mx-auto">
      {t.subtitle}
    </p>

    <div class="animate-on-scroll delay-2 flex justify-center">
      {t.actions.map((action) => (
        <a href={action.link} class="bg-white text-justice-navy px-8 py-3 rounded-full font-['Inter'] text-sm font-semibold hover:bg-surface-container transition-all">
          {action.cta}
        </a>
      ))}
    </div>
  </div>
</section>
