---
import { translations } from "../../locals/about/leadership";

type Locale = 'en' | 'hi' | 'fr';
const { local = 'en' } = Astro.params ?? {};
const t = translations[local as Locale] || translations['en'];
---

<section class="bg-background text-foreground py-24 px-4 sm:px-6 md:px-10 relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl -translate-x-1/2"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-16">
      <h2 class="animate-on-scroll text-3xl md:text-5xl font-extrabold mb-4">{t.title}</h2>
      <div class="animate-on-scroll scroll-scale w-24 h-1 bg-gradient-to-r from-primary via-accent to-primary mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {t.leaders.map((leader, index) => (
        <div class={`animate-on-scroll delay-${(index % 6) + 1} group glass-card rounded-3xl p-6 flex flex-col items-center text-center hover-lift`}>
          <div class="relative mb-4">
            <img src={leader.image} alt={leader.name} class="w-32 h-32 rounded-2xl object-cover" />
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <h3 class="text-xl font-bold">{leader.name}</h3>
          <p class="text-sm text-muted-foreground mt-1">{leader.position}</p>
        </div>
      ))}
    </div>
  </div>
</section>
